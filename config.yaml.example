channels:
  telegram:
    enabled: true
    chat_id: ""                    # 빈 문자열이면 .env TELEGRAM_CHAT_ID 사용

  slack:
    enabled: false
    channel_id: ""                 # 빈 문자열이면 .env SLACK_CHANNEL_ID 사용

broadcast:
  snippet_length: 500              # 상대 채널 브로드캐스트 요약 길이 (0이면 전체 발송)

alert:
  quiet_start: -1                  # 알림 무음 시작 시각 (0~23, -1이면 비활성)
  quiet_end: -1                    # 알림 무음 종료 시각 (0~23, 예: quiet_start: 23, quiet_end: 6 → 23시~06시 무음)

attachments:
  allowed_extensions:
    - txt
    - md
    - pdf
  max_file_size: 1048576                # 최대 파일 크기 (바이트, 1MB)
  temp_dir: messages/attachments
  reject_message: "txt, md, pdf 파일만 지원합니다."

polling:
  inbox_check_interval: 10
  outbox_interval: 3
  progress_interval: 60

archive:
  message_retention_days: 30

log:
  dir: logs
  retention_days: 14

claude:
  mode: headless
  dangerously_skip_permissions: true
  timeout: 600
  cooldown_retry_minutes: 10
  max_session_turns: 20
  working_dir: ""    # 사용자가 환경별 설정 (예: macOS /Users/kbj/..., Ubuntu /home/kbj/...)
  additional_dirs: []   

gsd:
  enabled: true
  timeout: 600000
  progress_check_interval: 60
  auto_mode: true
  auto_classify: true
  classify_model: haiku
  session_timeout_minutes: 30     # GSD 세션 유지 시간 (0이면 즉시 종료)
  history_max_messages: 5          # 세션 유실 시 이력 복원 최대 메시지 수

mcp:
  enabled: true
  allowed_directories: []    # 비어있으면 claude.working_dir 기본 사용

paths:
  inbox_dir: messages/inbox
  outbox_dir: messages/outbox
  sent_dir: messages/sent
  error_dir: messages/error
  archive_dir: messages/archive
  workqueue_dir: messages/workqueue
  plan_dir: messages/plan
